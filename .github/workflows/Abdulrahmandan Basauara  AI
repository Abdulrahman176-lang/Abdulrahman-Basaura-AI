<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Abdulrahman Basaura AI</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, sans-serif;
}

body{
background:#0d0d0d;
color:white;
display:flex;
height:100vh;
overflow:hidden;
}

/* Sidebar */
.sidebar{
width:250px;
background:#111;
padding:20px;
border-right:1px solid #222;
display:flex;
flex-direction:column;
justify-content:space-between;
}

.logo{
text-align:center;
margin-bottom:30px;
}

.logo h1{
color:gold;
font-size:28px;
}

.menu{
list-style:none;
}

.menu li{
padding:15px;
margin:10px 0;
background:#1a1a1a;
border-radius:10px;
cursor:pointer;
transition:0.3s;
}

.menu li:hover{
background:gold;
color:black;
font-weight:bold;
}

.bottom{
text-align:center;
font-size:14px;
color:#aaa;
}

/* Main Chat */
.main{
flex:1;
display:flex;
flex-direction:column;
}

.header{
padding:20px;
background:#111;
border-bottom:1px solid #222;
font-size:22px;
font-weight:bold;
color:gold;
}

.chat-box{
flex:1;
padding:20px;
overflow-y:auto;
}

.message{
max-width:70%;
padding:15px;
margin:10px 0;
border-radius:15px;
line-height:1.5;
}

.ai{
background:#1f1f1f;
align-self:flex-start;
}

.user{
background:gold;
color:black;
margin-left:auto;
}

.typing{
font-size:14px;
color:#999;
margin-top:5px;
animation:blink 1s infinite;
}

@keyframes blink{
50%{opacity:0.3;}
}

.input-area{
display:flex;
padding:15px;
background:#111;
border-top:1px solid #222;
}

.input-area input{
flex:1;
padding:15px;
border:none;
border-radius:10px;
outline:none;
background:#1a1a1a;
color:white;
font-size:16px;
}

.input-area button{
padding:15px 20px;
margin-left:10px;
border:none;
border-radius:10px;
background:gold;
color:black;
font-weight:bold;
cursor:pointer;
transition:0.3s;
}

.input-area button:hover{
background:white;
}

/* Mobile Responsive */
@media(max-width:768px){
.sidebar{
display:none;
}

.message{
max-width:90%;
}
}
</style>
</head>
<body>

<div class="sidebar">
<div>
<div class="logo">
<h1>AB AI</h1>
<p>Abdulrahman Basaura AI</p>
</div>

<ul class="menu">
<li><i class="fa fa-home"></i> Home</li>
<li><i class="fa fa-robot"></i> AI Chat</li>
<li><i class="fa fa-user"></i> Profile</li>
<li><i class="fa fa-cog"></i> Settings</li>
</ul>
</div>

<div class="bottom">
Powered by Abdulrahman Basaura AI
</div>
</div>

<div class="main">
<div class="header">
🤖 Abdulrahman Basaura AI
</div>

<div class="chat-box" id="chatBox">
<div class="message ai">
Assalamu Alaikum 👋
How can I help you today?
</div>
</div>

<div class="input-area">
<input type="text" id="userInput" placeholder="Type your message...">
<button onclick="sendMessage()">
<i class="fa fa-paper-plane"></i>
</button>
</div>
</div>

<script>
function sendMessage(){
const input=document.getElementById('userInput');
const chatBox=document.getElementById('chatBox');

if(input.value.trim()==='') return;

// User message
const userMsg=document.createElement('div');
userMsg.classList.add('message','user');
userMsg.innerText=input.value;
chatBox.appendChild(userMsg);

// Typing effect
const typing=document.createElement('div');
typing.classList.add('typing');
typing.innerText='Abdulrahman Basaura AI is typing...';
chatBox.appendChild(typing);

chatBox.scrollTop=chatBox.scrollHeight;

setTimeout(()=>{
typing.remove();

const aiMsg=document.createElement('div');
aiMsg.classList.add('message','ai');
aiMsg.innerText='Thank you for your message 😊';
chatBox.appendChild(aiMsg);

chatBox.scrollTop=chatBox.scrollHeight;
},1500);

input.value='';
}
</script>

</body>
</html>
